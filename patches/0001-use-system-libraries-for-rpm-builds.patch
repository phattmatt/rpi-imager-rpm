From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: rpi-imager-rpm maintainers <packagers@example.invalid>
Date: Sun, 19 Apr 2026 00:00:00 +0000
Subject: [PATCH] Use system libraries for RPM builds

Upstream's Linux build uses FetchContent for several libraries. RPM builds must
not download code during the build, so allow the spec to request distribution
libraries by setting RPM_USE_SYSTEM_LIBS.
---
 src/dependencies/curl.cmake       |  9 +++++++++
 src/dependencies/libarchive.cmake | 11 +++++++++++
 src/dependencies/libusb.cmake     | 13 +++++++++++++
 src/dependencies/nghttp2.cmake    | 11 +++++++++++
 src/dependencies/xz.cmake         | 11 +++++++++++
 src/dependencies/zlib.cmake       | 13 +++++++++++++
 src/dependencies/zstd.cmake       | 13 +++++++++++++
 7 files changed, 81 insertions(+)

diff --git a/src/dependencies/curl.cmake b/src/dependencies/curl.cmake
--- a/src/dependencies/curl.cmake
+++ b/src/dependencies/curl.cmake
@@ -1,4 +1,13 @@
 # Bundled libcurl
+
+if(DEFINED ENV{RPM_USE_SYSTEM_LIBS})
+    find_package(CURL REQUIRED)
+    set(CURL_FOUND TRUE CACHE BOOL "" FORCE)
+    set(CURL_LIBRARIES CURL::libcurl CACHE STRING "" FORCE)
+    set(CURL_INCLUDE_DIR ${CURL_INCLUDE_DIRS} CACHE STRING "" FORCE)
+    return()
+endif()
+
 
 set(CURL_VERSION "8.19.0")
 string(REPLACE "." "_" CURL_TAG ${CURL_VERSION})
diff --git a/src/dependencies/libarchive.cmake b/src/dependencies/libarchive.cmake
--- a/src/dependencies/libarchive.cmake
+++ b/src/dependencies/libarchive.cmake
@@ -1,4 +1,15 @@
 # Bundled libarchive configured for static zlib and zstd
+
+if(DEFINED ENV{RPM_USE_SYSTEM_LIBS})
+    find_package(LibArchive REQUIRED)
+    if(TARGET LibArchive::LibArchive)
+        set(LibArchive_LIBRARIES LibArchive::LibArchive CACHE STRING "" FORCE)
+    endif()
+    set(LibArchive_FOUND TRUE CACHE BOOL "" FORCE)
+    set(LibArchive_INCLUDE_DIR ${LibArchive_INCLUDE_DIRS} CACHE STRING "" FORCE)
+    return()
+endif()
+
 
 set(ENABLE_WERROR OFF CACHE BOOL "")
 set(ENABLE_INSTALL OFF CACHE BOOL "")
diff --git a/src/dependencies/libusb.cmake b/src/dependencies/libusb.cmake
--- a/src/dependencies/libusb.cmake
+++ b/src/dependencies/libusb.cmake
@@ -1,4 +1,17 @@
 # Bundled libusb for rpiboot USB communication
+
+if(DEFINED ENV{RPM_USE_SYSTEM_LIBS})
+    find_package(PkgConfig REQUIRED)
+    pkg_check_modules(LIBUSB REQUIRED IMPORTED_TARGET libusb-1.0)
+    set(LIBUSB_FOUND TRUE CACHE BOOL "" FORCE)
+    set(LIBUSB_INCLUDE_DIR ${LIBUSB_INCLUDE_DIRS} CACHE STRING "" FORCE)
+    set(LIBUSB_LIBRARIES PkgConfig::LIBUSB CACHE STRING "" FORCE)
+    if(NOT TARGET usb-1.0-static)
+        add_custom_target(usb-1.0-static)
+    endif()
+    return()
+endif()
+
 
 set(LIBUSB_VERSION "1.0.29")
 FetchContent_Declare(libusb
diff --git a/src/dependencies/nghttp2.cmake b/src/dependencies/nghttp2.cmake
--- a/src/dependencies/nghttp2.cmake
+++ b/src/dependencies/nghttp2.cmake
@@ -1,4 +1,15 @@
 # Remote nghttp2
+
+if(DEFINED ENV{RPM_USE_SYSTEM_LIBS})
+    find_package(PkgConfig REQUIRED)
+    pkg_check_modules(NGHTTP2 REQUIRED IMPORTED_TARGET libnghttp2)
+    set(NGHTTP2_FOUND TRUE CACHE BOOL "" FORCE)
+    set(NGHTTP2_LIBRARIES PkgConfig::NGHTTP2 CACHE STRING "" FORCE)
+    set(NGHTTP2_LIBRARY PkgConfig::NGHTTP2 CACHE STRING "" FORCE)
+    set(NGHTTP2_INCLUDE_DIR ${NGHTTP2_INCLUDE_DIRS} CACHE STRING "" FORCE)
+    return()
+endif()
+
 
 set(NGHTTP2_VERSION "1.68.1")
 FetchContent_Declare(nghttp2
diff --git a/src/dependencies/xz.cmake b/src/dependencies/xz.cmake
--- a/src/dependencies/xz.cmake
+++ b/src/dependencies/xz.cmake
@@ -1,4 +1,15 @@
 # Bundled liblzma (xz)
+
+if(DEFINED ENV{RPM_USE_SYSTEM_LIBS})
+    find_package(LibLZMA REQUIRED)
+    if(TARGET LibLZMA::LibLZMA)
+        set(LIBLZMA_LIBRARIES LibLZMA::LibLZMA CACHE STRING "" FORCE)
+    endif()
+    set(LIBLZMA_FOUND TRUE CACHE BOOL "" FORCE)
+    set(LIBLZMA_INCLUDE_DIR ${LIBLZMA_INCLUDE_DIRS} CACHE STRING "" FORCE)
+    return()
+endif()
+
 
 set(LIBLZMA_VERSION "5.8.2")
 FetchContent_Declare(xz
diff --git a/src/dependencies/zlib.cmake b/src/dependencies/zlib.cmake
--- a/src/dependencies/zlib.cmake
+++ b/src/dependencies/zlib.cmake
@@ -1,4 +1,17 @@
 # Bundled zlib
+
+if(DEFINED ENV{RPM_USE_SYSTEM_LIBS})
+    find_package(ZLIB REQUIRED)
+    set(ZLIB_FOUND TRUE CACHE BOOL "" FORCE)
+    set(ZLIB_LIBRARIES ZLIB::ZLIB CACHE STRING "" FORCE)
+    set(ZLIB_LIBRARY ZLIB::ZLIB CACHE STRING "" FORCE)
+    set(ZLIB_INCLUDE_DIR ${ZLIB_INCLUDE_DIRS} CACHE STRING "" FORCE)
+    if(NOT TARGET zlibstatic)
+        add_custom_target(zlibstatic)
+    endif()
+    return()
+endif()
+
 
 set(ZLIB_VERSION "1.3.2")
 set(ZLIB_BUILD_EXAMPLES OFF CACHE BOOL "" FORCE)
diff --git a/src/dependencies/zstd.cmake b/src/dependencies/zstd.cmake
--- a/src/dependencies/zstd.cmake
+++ b/src/dependencies/zstd.cmake
@@ -1,4 +1,17 @@
 # Bundled zstd
+
+if(DEFINED ENV{RPM_USE_SYSTEM_LIBS})
+    find_package(PkgConfig REQUIRED)
+    pkg_check_modules(ZSTD REQUIRED IMPORTED_TARGET libzstd)
+    set(ZSTD_FOUND TRUE CACHE BOOL "" FORCE)
+    set(Zstd_FOUND TRUE CACHE BOOL "" FORCE)
+    set(ZSTD_INCLUDE_DIR ${ZSTD_INCLUDE_DIRS} CACHE STRING "" FORCE)
+    set(Zstd_INCLUDE_DIR ${ZSTD_INCLUDE_DIRS} CACHE STRING "" FORCE)
+    set(ZSTD_LIBRARIES PkgConfig::ZSTD CACHE STRING "" FORCE)
+    set(Zstd_LIBRARIES PkgConfig::ZSTD CACHE STRING "" FORCE)
+    return()
+endif()
+
 
 set(ZSTD_VERSION "1.5.7")
 FetchContent_Declare(zstd
